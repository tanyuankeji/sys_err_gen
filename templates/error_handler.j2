// ============================================================================
// 系统错误监控模块 - 自动生成代码
// ============================================================================
// 生成工具: sys_err_gen
// Excel 来源: {{ excel_file }}
// Sheet 来源: {{ sheet_name }}
// 错误数量: {{ error_count }}
// ============================================================================
//
// 功能描述:
//   本模块监控系统各功能模块的数字信号，当检测到异常条件时产生对应的错误
//   标志。支持可配置的复位行为（RSTB）和功能安全（FuSa）控制。
//
// 设计原则:
//   1. 所有错误检测在时钟上升沿采样
//
// ============================================================================

`timescale 1ns / 1ps

module sys_err_gen #(
    // --------------------------------------------------------------------------
    // 可配置参数
    // --------------------------------------------------------------------------
) (
    // ======================================================================
    // io_declarations
    // 时钟与复位（固定）
    // ======================================================================
    input  wire                          sys_clk,            // 系统时钟
    input  wire                          sys_fs_rstn_sys,       // 异步复位，低有效
    input  wire                          fs_clk,             // 功能安全时钟
    input  wire                          sys_fs_rstn_fs,     // 功能安全异步复位，低有效

    // --------------------------------------------------------------------------
    // 监控输入信号
    // --------------------------------------------------------------------------
{% for err in errors %}
    input  wire                          {{ err["数字信号"] | pad_r(sig_max_width) }},  // {{ err["模块"] }} - {{ err["错误"] }}
{% endfor %}
    // --------------------------------------------------------------------------
    // 错误执行信号
    // --------------------------------------------------------------------------
{% for err in errors %}
    input  wire                          {{ err["数字信号"] }}_imp{{ " " | pad_r(imp_max_width - (err["数字信号"]|length) - 4) }},  // imp
{% endfor %}

    // ======================================================================
    // 用户代码
    // ======================================================================

    // --------------------------------------------------------------------------
    // 错误输出
    // --------------------------------------------------------------------------
    output wire [3:0]                    flt_err_cnt         // 故障错误计数器
);

    // ==========================================================================
    // 内部信号定义
    // ==========================================================================

{% for err in errors %}
    wire                                 {{ err["数字信号"]}}_hs;      // 同步到 hs 域
{% endfor %}


{% for err in errors %}
    wire                                 {{ err["数字信号"]}}_fs;      // 同步到 fs 域
{% endfor %}


{% for err in errors %}
    wire                                 {{ err["数字信号"]}}_fs_d;    // fs 域打一拍
    wire                                 {{ err["数字信号"]}}_fs_pos;  // fs 域上升沿
{% endfor %}


{% for err in errors %}
    wire                                 {{ err["数字信号"]}}_imp_sync; // imp 同步到 fs 域
{% endfor %}


    // ======================================================================
    // sync to hs 
    // ======================================================================
{% for err in errors %}
    clk_tran_2 utran_{{ err["数字信号"]}}_hs (.clk(sys_clk), .rstn(sys_fs_rstn_sys), .signal_in({{ err["数字信号"]}}), .signal_out({{ err["数字信号"]}}_hs));  // {{ err["模块"] }} - {{ err["错误"] }}
{% endfor %}


    // ==========================================================================
    // sync to fs
    // ==========================================================================
{% for err in errors %}
    clk_tran_2 utran_{{ err["数字信号"]}}_fs (.clk(fs_clk), .rstn(sys_fs_rstn_fs), .signal_in({{ err["数字信号"]}}), .signal_out({{ err["数字信号"]}}_fs));  // {{ err["模块"] }} - {{ err["错误"] }}
{% endfor %}


    // ======================================================================
    // fs 域打拍与上升沿检测
    // ======================================================================
{% for err in errors %}
    dff_pn #(1, 0) regx_{{ err["数字信号"]}}_fs_d (.clk(fs_clk), .rstn(sys_fs_rstn_fs), .din({{ err["数字信号"]}}_fs), .dout({{ err["数字信号"]}}_fs_d));  // {{ err["模块"] }} - {{ err["错误"] }}
{% endfor %}

{% for err in errors %}
    assign {{ err["数字信号"]}}_fs_pos = {{ err["数字信号"]}}_fs & ~{{ err["数字信号"]}}_fs_d;
{% endfor %}

    // ==========================================================================
    // imp sync to fs
    // ==========================================================================
    // 如果RSTB非空，则该项imp[0]有效
    // 如果FuSa非空，则该项imp[1]有效
    // 位宽也对应
{% for err in errors %}
    clk_tran_2 #(2, 0)utran_{{ err["数字信号"]}}_imp_sync (.clk(fs_clk), .rstn(sys_fs_rstn_fs), .signal_in({{ err["数字信号"]}}_imp), .signal_out({{ err["数字信号"]}}_imp_sync));  // {{ err["模块"] }} - {{ err["错误"] }}
{% endfor %}


{% if has_rstb %}
    // ======================================================================
    // RSTB - 复位请求逻辑（仅包含 RSTB 非空的错误项）
    // ======================================================================
    // 如果 RSTB 非空，则该信号具备复位请求源
    assign rstb_req_pre = {
{% for err in rstb_errors %}
        {{err["数字信号"]}}_fs_pos{% if not loop.last %},
{% endif %}
{% endfor %}
    };

    // 如果 RSTB 非空，则该 imp[0] 使能位有效
    assign rstb_en = {
{% for err in rstb_errors %}
        {{ err["数字信号"]}}_imp_sync[0]{% if not loop.last %},
{% endif %}
{% endfor %}
    };
{% endif %}


    assign sys_err_rstb_req_pre = |(rstb_req_pre & rstb_en);
    dff_pn #(1, 0) regx_sys_err_rstb_req (.clk(fs_clk), .rstn(sys_fs_rstn_fs), .din(sys_err_rstb_req_pre), .dout(sys_err_rstb_req)); 
    

{% if has_fusa %}
    // ======================================================================
    // FuSa - 功能安全请求逻辑（仅包含 FuSa 非空的错误项）
    // ======================================================================
    // 如果 FuSa 非空，则该信号具备功能安全请求源
    assign fsxb_req_pre = {
{% for err in fusa_errors %}
        {{ err["数字信号"]}}_fs_pos{% if not loop.last %},
{% endif %}
{% endfor %}
    };

    // 如果 FuSa 非空，则该 imp[1] 使能位有效
    assign sys_err_fsxb_en = {
{% for err in fusa_errors %}
        {{ err["数字信号"]}}_imp_sync[1]{% if not loop.last %},
{% endif %}
{% endfor %}
        };
{% endif %}

    assign sys_err_fsxb_req_pre = |(fsxb_req_pre & fusa_en);
    dff_pn #(1, 0) regx_sys_err_fsxb_req (.clk(fs_clk), .rstn(sys_fs_rstn_fs), .din(sys_err_fsxb_req_pre), .dout(sys_err_fsxb_req)); 
    
{% if has_fltcnt %}
    // ==========================================================================
    // FLT_ERR_CNT - 故障错误计数器逻辑（仅包含 FLT_ERR_CNT 非空的错误项）
    // ======================================================================
    // 如果 FLT_ERR_CNT 非空，则该信号参与故障计数
    assign sys_err_err_cnt_add1_pre = {
{% for err in fltcnt_errors %}
        {{ err["数字信号"]}}_fs_pos{% if not loop.last %},
{% endif %}
{% endfor %}
        };

    // 故障计数使能（统一使能）
    assign flt_cnt_en = {
{% for err in fltcnt_errors %}
        1'b1{% if not loop.last %},  //{{ err["数字信号"]}}
{% endif %}
{% endfor %}
        };

    assign sys_err_err_cnt_add1 = sys_err_err_cnt_add1_pre & flt_cnt_en;
    assign sys_err_fault_cnt_add1_pre = |sys_err_err_cnt_add1;
    dff_pn #(1, 0) regx_sys_err_fault_cnt_add1 (.clk(fs_clk), .rstn(sys_fs_rstn_fs), .din(sys_err_fault_cnt_add1_pre), .dout(sys_err_fault_cnt_add1)); 

    // 故障计数累加
    assign bit_all =
{% for err in fltcnt_errors %}
        sys_err_err_cnt_add1[{{ loop.index0 }}]{% if not loop.last %} +
{% endif %}
{% endfor %}
        ;

{% endif %}

    assign sys_err_fault_cnt_pre = (bit_all >= 5'd6) ? 3'd6 : bit_all[2:0];
    dff_pn #(3, 3'd0) regx_sys_err_fault_cnt (.clk(fs_clk), .rstn(sys_fs_rstn_fs), .din(sys_err_fault_cnt_pre), .dout(flt_err_cnt));  

    // ==========================================================================
    // 其他固定逻辑
    // ==========================================================================


endmodule
