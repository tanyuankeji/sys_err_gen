// ============================================================================
// 系统错误监控模块 - 自动生成代码
// ============================================================================
// 生成工具: sys_err_gen
// Excel 来源: {{ excel_file }}
// Sheet 来源: {{ sheet_name }}
// 错误数量: {{ error_count }}
// ============================================================================
//
// 功能描述:
//   本模块监控系统各功能模块的数字信号，当检测到异常条件时产生对应的错误
//   标志。支持可配置的复位行为（RSTB）和功能安全（FuSa）控制。
//
// 设计原则:
//   1. 所有错误检测在时钟上升沿采样
//
// ============================================================================

`timescale 1ns / 1ps

module sys_err_gen #(
    // --------------------------------------------------------------------------
    // 可配置参数
    // --------------------------------------------------------------------------
) (
    // --------------------------------------------------------------------------
    // 时钟与复位
    // --------------------------------------------------------------------------
    input  wire                          sys_clk,              // 系统时钟
    input  wire                          sys_rst_n,            // 异步复位，低有效
    input  wire                          fs_clk,                   
    input  wire                          fs_rst_n,             // 异步复位，低有效

    // --------------------------------------------------------------------------
    // 监控输入信号
    // --------------------------------------------------------------------------
{% for err in errors %}
    input  wire                          {{ err["数字信号"] }},  // {{ err["模块"] }} - {{ err["错误"] }}
{% endfor %}
    
    // --------------------------------------------------------------------------
    // 错误执行
    // --------------------------------------------------------------------------
{% for err in errors %}
    input  wire                          {{ err["数字信号"] }}_imp,  // imp
{% endfor %}

    // --------------------------------------------------------------------------
    // 错误输出
    // --------------------------------------------------------------------------
    output wire [3:0]                    flt_err_cnt       // 故障错误计数器
);

    // ==========================================================================
    // 内部信号定义
    // ==========================================================================
    // 
    reg  [ERROR_COUNT-1:0]               err_flags_reg;
    reg  [ERROR_COUNT-1:0]               err_flags_next;

    // 错误码寄存器
    reg  [ERR_CODE_WIDTH-1:0]            err_code_reg;
    reg  [ERR_CODE_WIDTH-1:0]            err_code_next;

    // 故障计数器
    reg  [3:0]                           flt_err_cnt_reg;
    reg  [3:0]                           flt_err_cnt_next;
    reg                                  flt_err_cnt_inc;  // 计数器递增标志

    // ==========================================================================
    // 错误码定义 (Localparam)
    // ==========================================================================
{% for err in errors %}
    localparam ERR_CODE_{{ err["数字信号"] | upper }}  = 8'h{{ "%02X" % (loop.index + 16) }};  // {{ err["模块"] }} - {{ err["错误"] }}
{% endfor %}
    // ==========================================================================
    // 主时序逻辑: 错误标志寄存器
    // ==========================================================================
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            err_flags_reg <= {ERROR_COUNT{1'b0}};
        end else begin
            err_flags_reg <= err_flags_next;
        end
    end

    // ==========================================================================
    // 组合逻辑: 错误标志更新
    // ==========================================================================
    always @(*) begin
        err_flags_next = err_flags_reg;
{% for err in errors %}
        // {{ err["模块"] }} - {{ err["错误"] }}: 监测 {{ err["数字信号"] }}
        if ({{ err["数字信号"] }}) begin
            err_flags_next[{{ loop.index0 }}] = 1'b1;
        end else if (err_rstb) begin
            err_flags_next[{{ loop.index0 }}] = 1'b0;
        end
{% endfor %}
    end

    // ==========================================================================
    // 主时序逻辑: 错误码寄存器
    // ==========================================================================
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            err_code_reg <= {ERR_CODE_WIDTH{1'b0}};
        end else begin
            err_code_reg <= err_code_next;
        end
    end

    // ==========================================================================
    // 组合逻辑: 错误码优先级编码器
    // 优先级: 低索引 > 高索引（索引 0 优先级最高）
    // ==========================================================================
    always @(*) begin
        err_code_next = {ERR_CODE_WIDTH{1'b0}};
{% for err in errors %}
        if (err_flags_reg[{{ loop.index0 }}]) begin
{% if loop.first %}
            err_code_next = ERR_CODE_{{ err["数字信号"] | upper }};
{% else %}
            if (!err_flags_reg[{{ loop.index0 - 1 }}:0]) begin
                err_code_next = ERR_CODE_{{ err["数字信号"] | upper }};
            end
{% endif %}
        end
{% endfor %}
    end

    // ==========================================================================
    // 主时序逻辑: 故障错误计数器
    // ==========================================================================
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            flt_err_cnt_reg <= 4'd0;
        end else begin
            flt_err_cnt_reg <= flt_err_cnt_next;
        end
    end

    // ==========================================================================
    // 组合逻辑: 故障计数器更新
    // ==========================================================================
    always @(*) begin
        flt_err_cnt_next = flt_err_cnt_reg;
        flt_err_cnt_inc = 1'b0;
{% for err in errors %}
{% if err["FLT_ERR_CNT"] and err["FLT_ERR_CNT"] != "" %}
        // {{ err["模块"] }} - {{ err["错误"] }} 触发时计数器递增
        if (err_flags_reg[{{ loop.index0 }}] && !err_flags_next[{{ loop.index0 }}]) begin
            flt_err_cnt_next = flt_err_cnt_reg + 4'd1;
        end
{% endif %}
{% endfor %}
        // 复位时清零计数器
        if (err_rstb && (err_flags_reg == {ERROR_COUNT{1'b0}})) begin
            flt_err_cnt_next = 4'd0;
        end
    end

    // ==========================================================================
    // 输出赋值
    // ==========================================================================
    assign err_flags   = err_flags_reg;
    assign err_code    = err_code_reg;
    assign err_valid   = |err_flags_reg;                // 任意错误标志有效
    assign flt_err_cnt = flt_err_cnt_reg;

endmodule
